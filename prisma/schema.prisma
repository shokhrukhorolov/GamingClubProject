generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlaceType {
  SEAT
  ROOM_UNIT
}

enum PlaceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum BookingStatus {
  ACTIVE
  CANCELLED
}

enum BookingSource {
  CLIENT
  ADMIN
}

enum BalanceTransactionType {
  TOPUP_ADMIN
  BOOKING_CHARGE
  BOOKING_REFUND
}

enum ClubStatus {
  ACTIVE
  COMING_SOON
}

model Club {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  city        String     @default("Tashkent")
  address     String?
  description String?
  imageUrl    String?
  rating      Decimal?   @db.Decimal(2, 1)
  status      ClubStatus @default(COMING_SOON)
  isMain      Boolean    @default(false)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("clubs")
}

model Snack {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookingSnacks BookingSnack[]

  @@map("snacks")
}

model BookingSnack {
  id String @id @default(cuid())

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  snackId String
  snack   Snack  @relation(fields: [snackId], references: [id], onDelete: Restrict)

  quantity      Int     @default(1)
  priceSnapshot Decimal @db.Decimal(10, 2)

  @@index([bookingId])
  @@map("booking_snacks")
}

model Room {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  places Place[]

  @@map("rooms")
}

model Category {
  id                  String   @id @default(cuid())
  name                String   @unique
  defaultPricePerHour Decimal  @db.Decimal(10, 2)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  places Place[]

  @@map("categories")
}

model Place {
  id           String      @id @default(cuid())
  name         String
  type         PlaceType   @default(SEAT)
  status       PlaceStatus @default(ACTIVE)
  pricePerHour Decimal     @db.Decimal(10, 2)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([categoryId])
  @@index([roomId])
  @@map("places")
}

model Client {
  id           String  @id @default(cuid())
  name         String
  phone        String  @unique
  email        String?
  passwordHash String?
  balance      Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings            Booking[]
  balanceTransactions BalanceTransaction[]

  @@map("clients")
}

model BalanceTransaction {
  id String @id @default(cuid())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  type   BalanceTransactionType
  amount Decimal                @db.Decimal(12, 2) // signed: credit +, debit -
  note   String?

  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@map("balance_transactions")
}

model Booking {
  id String @id @default(cuid())

  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Restrict)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  startsAt DateTime
  endsAt   DateTime

  pricePerHourSnapshot Decimal @db.Decimal(10, 2)
  totalPrice           Decimal @db.Decimal(10, 2)

  status BookingStatus @default(ACTIVE)
  source BookingSource @default(ADMIN)

  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balanceTransactions BalanceTransaction[]
  snacks              BookingSnack[]

  @@index([placeId, startsAt, endsAt])
  @@index([clientId])
  @@index([status])
  @@map("bookings")
}
